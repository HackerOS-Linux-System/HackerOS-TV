// curl
// apt

> sudo apt install -y cage
> sudo curl -L -o /usr/bin/HackerOS-TV "https://github.com/HackerOS-Linux-System/HackerOS-TV/releases/download/v0.1/HackerOS-TV" && sudo chmod +x /usr/bin/HackerOS-TV
> sudo curl -L -o /usr/share/applications/HackerOS-TV.desktop "https://raw.githubusercontent.com/HackerOS-Linux-System/HackerOS-TV/main/desktop/HackerOS-TV.desktop"
> sudo curl -L -o /usr/share/wayland-sessions/HackerOS-TV.desktop "https://raw.githubusercontent.com/HackerOS-Linux-System/HackerOS-TV/main/desktop/HackerOS-TV-Session.desktop"
